# Copy to .env.local and adjust if your services run on non-default ports.
#
# BACKEND_URL — BacktestStation FastAPI. Default :8000 matches the sidecar
# uvicorn binding the Tauri shell launches on dev, and the NSSM service on
# the production server.
BACKEND_URL=http://127.0.0.1:8000

# SIDECAR_URL — research_sidecar HTTP API (Phase C). Default :9000 matches
# the HTTP_API_PORT in research_sidecar/app/config.py. Co-located with
# BacktestStation on ben-247 in production; the Tailscale binding lives on
# the sidecar's uvicorn `--host`, not here.
SIDECAR_URL=http://127.0.0.1:9000
