# Local market data — never commit. Anchored to repo root so
# unrelated `data/` directories under frontend/, backend/, etc. are NOT
# ignored.
/data/
!/data/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
backend/tests/_artifacts/
*.egg-info/
dist/
build/

# Node / Next.js
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo

# Tauri (Rust) build artifacts
frontend/src-tauri/target/
frontend/src-tauri/gen/
frontend/src-tauri/WixTools/

# Env / secrets
.env
.env.local
.env.*.local

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
