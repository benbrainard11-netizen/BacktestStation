# Local market data — never commit. Anchored to repo root so
# unrelated `data/` directories under frontend/, backend/, etc. are NOT
# ignored.
/data/
!/data/.gitkeep

# Local-only staging area for one-time data jobs (e.g. archive
# extraction before partition). Files here are big + source-of-truth
# is elsewhere on disk; never commit.
/staging/

# Local server logs from dev runs.
/logs/

# Generated share packages. These can contain large parquet datasets and
# should be shared intentionally, not committed.
/exports/

# Database backups (multi-GB sqlite snapshots). Local-only.
/experiments/db_backups/

# Overnight queue per-task logs (verbose). Keep MASTER_LOG.md only.
/experiments/overnight_runs/*/[0-9]*.log
/experiments/overnight_runs/*/0[0-9]_*.log
/experiments/overnight_runs/*/[0-9][0-9]_*.log

# Detector-run logs from generate_events_* scripts.
/backend/scripts/logs/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
backend/tests/_artifacts/
*.egg-info/
dist/
build/
# Re-include Next.js route directories named "build" — they're source,
# not Python build artifacts. Anchored under frontend/app/ so the
# generic `build/` rule still catches Python output everywhere else.
!frontend/app/**/build/
!frontend/app/**/build/**

# Node / Next.js
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo

# Tauri (Rust) build artifacts
frontend/src-tauri/target/
frontend/src-tauri/gen/
frontend/src-tauri/WixTools/

# Playwright
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
frontend/playwright/.cache/

# Env / secrets
.env
.env.local
.env.*.local

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Local-only dev artifacts — pre-redesign frontend snapshot kept for
# reference, plus the unpacked Claude Design source bundle. Never commit.
/_frontend_archive_2026_05_01/
/design_extract/

# Local machine-specific launcher.
/start_server.ps1

# Claude Code internal state (scheduler lock, etc).
.claude/scheduled_tasks.lock

# GPU run artifacts are tracked per-experiment under experiments/backtests/.
# The /experiments/gpu_runs/ subtree was an earlier experiments layout that
# we don't track anymore — keep on disk for reference, don't commit.
/experiments/gpu_runs/

# Audit bundle artifacts (regenerable via scripts/build_audit_bundle.py)
BacktestStation_R2_audit_bundle/
BacktestStation_R2_audit_bundle.zip
