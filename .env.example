# BacktestStation environment variables — example / documentation
#
# This file is NOT loaded automatically. It exists as a reference for
# what env vars the backend, ingester, and clients expect. On Windows,
# set them at User scope via PowerShell:
#
#   [Environment]::SetEnvironmentVariable("VAR_NAME", "value", "User")
#
# Or at Machine scope (so scheduled tasks pick them up without a logon):
#
#   [Environment]::SetEnvironmentVariable("VAR_NAME", "value", "Machine")
#
# After setting, restart your shell to see them in $env:.

# ============================================================================
# Local warehouse (ben-247 + benpc + Husky's machine)
# ============================================================================

# Root of the on-disk parquet warehouse. Contains raw/, processed/,
# manifests/, heartbeat/, logs/. See backend/app/core/paths.py:51.
# Default: C:/data on Windows, ./data elsewhere.
BS_DATA_ROOT=D:\data

# Databento API key. ben-247 only — never set on benpc or Husky's machine.
# Used by the live ingester (app.ingest.live) and historical pulls.
DATABENTO_API_KEY=db-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Cloud R2 mirror (uploader + clients)
# ============================================================================
# See docs/R2_SETUP.md for the bucket + token setup.

# Cloudflare R2 bucket name. Single bucket holds the read-side warehouse
# mirror (processed/bars + raw/databento). Default: bsdata-prod.
BS_R2_BUCKET=bsdata-prod

# R2 endpoint URL. Format: https://<account-id>.r2.cloudflarestorage.com
# Get the account ID from the Cloudflare dashboard → R2 → Account ID.
BS_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# R2 API token credentials. TWO different scopes — set whichever fits
# the host:
#   - On ben-247 (uploader host): use the WRITE-scope token
#   - On benpc / Husky's machine (reader hosts): use the READ-scope token
BS_R2_ACCESS_KEY=your-r2-access-key
BS_R2_SECRET=your-r2-secret-key

# Backend selector for the data reader. Set on collaborator machines that
# don't have a local warehouse to read R2 instead of disk. Defaults to
# "local" (read from BS_DATA_ROOT).
#   local → LocalStorage(BS_DATA_ROOT)  [default]
#   r2    → R2Storage (requires BS_R2_*)
BS_DATA_BACKEND=local

# Optional: where the bsdata client puts its local R2 cache. Default:
# ~/.bsdata/cache (Hive-partitioned, mirrors the warehouse layout).
BS_R2_CACHE_ROOT=
